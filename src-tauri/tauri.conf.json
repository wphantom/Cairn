{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "width": 480,
        "height": 600,
        "minWidth": 360,
        "minHeight": 400,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "resizable": true,
        "center": true,
        "url": "index.html",
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png"],
    "resources": ["icons/"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "productName": "Cairn",
  "identifier": "fr.sylvainclement.cairn",
  "version": "0.1.0"
}
